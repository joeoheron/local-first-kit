{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview",
    "dev:workers": "vite build && wrangler dev -c wrangler.dev.jsonc",
    "db:local": "wrangler d1 migrations apply DB --local -c wrangler.dev.jsonc",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check-types": "npm run check",
    "test": "echo 'No tests yet. See docs/scenarios/persistence-lifecycle-scenarios.md for testable invariants.' && exit 0"
  },
  "dependencies": {
    "@local-first-kit/auth": "*",
    "@local-first-kit/config": "*",
    "@local-first-kit/data": "*",
    "@local-first-kit/domain": "*",
    "bits-ui": "^1.3.22",
    "tinybase": "^8.2.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.31.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.2",
    "@unocss/preset-mini": "^66.1.1",
    "@unocss/transformer-directives": "^66.1.1",
    "@unocss/transformer-variant-group": "^66.1.1",
    "alchemy": "^0.82.1",
    "svelte": "^5.38.1",
    "svelte-check": "^4.3.1",
    "typescript": "^5",
    "unocss": "^66.1.1",
    "vite": "^7.1.2",
    "wrangler": "^4.87.0"
  }
}
